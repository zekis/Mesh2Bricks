# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output
dist/
build/
.vite/
*.tsbuildinfo

# Per-session pipeline state (regenerated each run)
.state/

# LDraw runner — disk-cached .dat fetches and the runner's manifest output.
# The canonical manifest lives at phase0/public/ldraw/manifest.json and IS
# committed, since the web app loads it at runtime.
ldraw_runner/cache/
ldraw_runner/out/

# Python (trellis_runner, omr_runner, data_gen)
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Large mesh test inputs at the repo root (Meshy/TRELLIS exports). Sub-
# project .glb assets are generally ignored — see "trellis_*.glb" rule
# below to cover them no matter which subdir they land in.
/*.glb
/*.gltf

# TRELLIS-generated meshes anywhere in the tree. These are produced by
# the trellis runner / data_gen pipeline and are regeneratable.
**/trellis_*.glb
**/trellis_*.ply
**/trellis_*.gltf

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Logs
*.log

# Memory / assistant scratch (per-machine, not source)
.claude/

# Environment files (in case any get added later)
.env
.env.local
.env.*.local

# ── phase1/refine — ML training artifacts and regeneratable data ──────────
#
# Everything in this section is either (a) checkpoint/output of a training
# run, (b) intermediate data the build_* / data_* scripts regenerate, or
# (c) experiment products (renders, search results). The .py code is
# committed; the outputs are not.

# Training runs (checkpoints, logs, renders, metrics) — currently ~8.5 GB
phase1/refine/runs/

# Generated training data (huge: 700MB-1GB each)
phase1/refine/train_*.jsonl
phase1/refine/placements*.jsonl

# Built fitter↔OMR pair JSONs (regenerate via build_pairs.py)
phase1/refine/pairs_v0/

# Voxel hulls (.npy + matching .json transform), wherever they land
phase1/refine/*.npy
phase1/refine/training_pairs/

# TRELLIS / pipeline outputs
phase1/refine/dragon_*
phase1/refine/*_voxel.npy
phase1/refine/*_voxel.json
phase1/refine/*_lego.*
phase1/refine/lego_from_image_out.*

# Render scratch directories
phase1/refine/clip_validate_out/
phase1/refine/search_clip_renders/
phase1/refine/ldraw_render_test.png

# Search experiment outputs
phase1/refine/search_*.json
phase1/refine/search_*_out.json

# Vocab/lookup tables emitted by data-prep scripts (regeneratable, several MB each)
phase1/refine/action_lookup.json
phase1/refine/action_vocab.json
phase1/refine/v4_extras.json

# Viewer build artifacts
phase1/refine/viewer/dist/
phase1/refine/viewer/node_modules/

# Official LDraw library — 586 MB of downloaded parts, models, primitives.
# Not source we develop; users grab it from https://www.ldraw.org/ on
# setup. The code in phase1/refine/ldraw_parser.py reads from this.
complete/ldraw/
complete/ldraw.zip
complete.zip

# ── phase1 — data files generated by scrapers / data prep pipelines ──────
#
# Most phase1/ subprojects produce piles of intermediate .npy/.mpd/.ldr/.pt
# files that are regeneratable from the source scripts. Ignore by file
# extension across all of phase1; source code (.py, .ts) stays tracked.

# Numpy intermediates (voxel hulls, embeddings, etc.)
phase1/**/*.npy

# LDraw model files (downloaded OMR sets + scratch renders)
phase1/**/*.mpd
phase1/**/*.ldr

# PyTorch checkpoints / state dicts (anywhere outside runs/, just in case)
phase1/**/*.pt
phase1/**/*.pth

# Tabular logs
phase1/**/*.csv

# Big JSON dumps from data prep — but NOT vocabs.json / move_vocab.json
# / connections.json which the model code loads at runtime. (Caller can
# choose to commit a manifest or two by name with explicit `git add -f`.)
phase1/omr_runner/*.json
phase1/omr_runner/raw/
phase1/omr_runner/training_pairs/
phase1/omr_runner/placements.jsonl
phase1/omr_runner/failed.txt
phase1/omr_runner/cubic_rotations.npy

# Per-stud-snap experiment outputs
phase1/stud_snap/runs/

# Old phase1/train experiment outputs
phase1/train/runs/
phase1/train/gen_*.ldr
phase1/train/generated*.ldr
phase1/train/g_*.ldr

# Per-subproject Node deps + build
phase1/data_gen/node_modules/
phase1/data_gen/work/
phase1/**/dist/
